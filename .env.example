TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=
ADMIN_DELETE_KEY=
RATE_LIMIT_ENFORCE=0

# --- solana (crashgame) ---
# NEXT_PUBLIC_SOLANA_CLUSTER: "devnet" for testing, "mainnet-beta" for production.
# NEXT_PUBLIC_SOLANA_RPC_ENDPOINT: Full RPC URL. Helius free tier recommended —
#   sign up at https://helius.dev, create an API key, use the endpoint below.
#   Leave blank to fall back to the public Solana RPC (rate-limited, not for prod).
# CRASHGAME_PROGRAM_ID: Set this AFTER running `anchor deploy` on devnet.
#   Copy the Program Id from the deploy output (e.g. AncXyz...1234).
# CRASHGAME_AUTHORITY_SECRET: Base58-encoded keypair (64-byte Uint8Array encoded
#   as base58) used by the FastAPI server to sign commit_round and settle_round
#   Anchor instructions. Generate with `solana-keygen new --outfile authority.json`
#   then `base58-encode authority.json`. Keep this secret — never commit it.
# CRASHGAME_TREASURY_PUBKEY: Public key of the wallet that receives the house rake
#   on each settled round. Does not need to be the same as the authority keypair.
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC_ENDPOINT=
HELIUS_API_KEY=
CRASHGAME_PROGRAM_ID=
CRASHGAME_AUTHORITY_SECRET=
CRASHGAME_TREASURY_PUBKEY=
